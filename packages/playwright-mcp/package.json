{
  "name": "playwright-sessions",
  "version": "0.3.0",
  "description": "Playwright MCP with persistent named sessions — save/restore browser auth, clone sessions, manage multiple isolated contexts. Fork of microsoft/playwright-mcp.",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gabrielantonyxaviour/playwright-sessions.git"
  },
  "homepage": "https://github.com/gabrielantonyxaviour/playwright-sessions",
  "engines": {
    "node": ">=18"
  },
  "author": {
    "name": "Gabriel Antony Xavier"
  },
  "license": "Apache-2.0",
  "keywords": [
    "playwright",
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "sessions",
    "browser-automation",
    "claude",
    "claude-code",
    "claude-code-plugin",
    "ai",
    "llm",
    "testing",
    "e2e"
  ],
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "dist/**/*.js.map",
    "src/**/*.ts"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "test": "playwright test",
    "prepublishOnly": "npm run build"
  },
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "playwright": "^1.52.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0"
  },
  "bin": {
    "playwright-sessions": "dist/index.js"
  }
}
